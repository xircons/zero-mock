{
  "name": "@xirconsss/zero-mock",
  "version": "0.1.0",
  "description": "Zero-config CLI that generates REST APIs from JSON files",
  "license": "MIT",
  "keywords": [
    "mock",
    "api",
    "server",
    "cli",
    "rest",
    "json-database",
    "frontend-tool",
    "express",
    "zero-config",
    "json"
  ],
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "example"
  ],
  "bin": {
    "zero-mock": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xircons/zero-mock.git"
  },
  "bugs": {
    "url": "https://github.com/xircons/zero-mock/issues"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "cors": "^2.8.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
