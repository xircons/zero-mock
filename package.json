{
  "name": "@xirconsss/zero-mock",
  "version": "1.2.1",
  "description": "Zero-config CLI that generates REST APIs from JSON files",
  "license": "MIT",
  "keywords": [
    "mock",
    "api",
    "server",
    "cli",
    "rest",
    "json-database",
    "frontend-tool",
    "express",
    "zero-config",
    "json"
  ],
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "example"
  ],
  "bin": {
    "zero-mock": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xircons/zero-mock.git"
  },
  "bugs": {
    "url": "https://github.com/xircons/zero-mock/issues"
  },
  "homepage": "https://github.com/xircons/zero-mock#readme",
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "gradient-string": "^3.0.0",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^22.14.0",
    "@vitest/coverage-v8": "^2.1.9",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  }
}
